classDiagram
    class Task {
        +str id
        +str title
        +int duration_minutes
        +str priority
        +str category
        +time fixed_time
        +bool is_recurring
        +str recurrence
        +bool completed
        +date due_date
        +mark_complete() Task
        +mark_incomplete() None
        +next_occurrence() Task
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task) None
        +remove_task(task_id) None
        +pending_tasks() list~Task~
        +complete_task(task_id) Task
    }

    class Owner {
        +str name
        +dict preferences
        +list~Pet~ pets
        +add_pet(pet) None
        +get_all_tasks() list~tuple~
    }

    class ScheduledItem {
        +Pet pet
        +Task task
        +time start_time
        +time end_time
        +str reason
    }

    class Scheduler {
        +time day_start
        +build_plan(owner, available_minutes) list~ScheduledItem~
        +explain(plan) str
        +sort_by_time(tasks) list~Task~
        +filter_tasks(owner, pet_name, completed) list~Task~
        +detect_conflicts(owner) list~str~
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Pet ..> Task : creates next occurrence via mark_complete()
    Scheduler ..> Owner : reads tasks via get_all_tasks()
    Scheduler ..> ScheduledItem : produces
    ScheduledItem --> Pet : references
    ScheduledItem --> Task : references
